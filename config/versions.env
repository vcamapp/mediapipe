PACKAGE_VERSION="0.0.4"
PACKAGE_BUILD="1"
MEDIAPIPE_VERSION="0.10.35"
MINIMUM_IOS_VERSION="17.0"
MINIMUM_MACOS_VERSION="14.0"
# OpenCV statically linked into the macOS artifact (see macos/README.md).
OPENCV_VERSION="4.13.0"
# Prebuilt CPU-only static library for macOS, built from patched MediaPipe
# sources (see macos/README.md). Override MACOS_ARTIFACT_PATH to use a local
# zip instead of downloading.
MACOS_ARTIFACT_URL="https://github.com/vcamapp/mediapipe/releases/download/macos-${MEDIAPIPE_VERSION}/MediaPipeTasksVision-macos-arm64-${MEDIAPIPE_VERSION}.zip"
MACOS_ARTIFACT_SHA256="2292fa101676b3842a12a2caff75f6e7e4b3abee7d5bf8bd890b81b5a5e864b8"
# Objective-C classes that every released binary (iOS and macOS) must export.
# Consumed by scripts/validate.sh and macos/build-macos-static-lib.sh.
REQUIRED_OBJC_CLASSES="MPPFaceLandmarker MPPGestureRecognizer MPPHandLandmarker MPPHolisticLandmarker MPPPoseLandmarker"
