diff --git a/.bazelrc b/.bazelrc
index 5965f96..97e5d9f 100644
--- a/.bazelrc
+++ b/.bazelrc
@@ -122,6 +122,17 @@ build:darwin_arm64 --apple_platform_type=macos
 build:darwin_arm64 --macos_minimum_os=10.16
 build:darwin_arm64 --cpu=darwin_arm64
 
+# Required for the macOS static library build (see macos/README.md in the
+# distribution repository):
+# - TensorFlow's hermetic Python needs a version with a requirements lock;
+#   the interpreter is downloaded, so the host Python version is irrelevant.
+# - Bazel 7 removed its builtin Apple C++ toolchain; objc_library requires
+#   the apple_support crosstool.
+common --repo_env=HERMETIC_PYTHON_VERSION=3.12
+build:macos --apple_crosstool_top=@local_config_apple_cc//:toolchain
+build:macos --crosstool_top=@local_config_apple_cc//:toolchain
+build:macos --host_crosstool_top=@local_config_apple_cc//:toolchain
+
 # Turn off maximum stdout size
 build --experimental_ui_max_stdouterr_bytes=-1
 
