diff --git a/mediapipe/tasks/ios/vision/hand_landmarker/smoke_objc_macos.mm b/mediapipe/tasks/ios/vision/hand_landmarker/smoke_objc_macos.mm
new file mode 100644
index 0000000..8fae760
--- /dev/null
+++ b/mediapipe/tasks/ios/vision/hand_landmarker/smoke_objc_macos.mm
@@ -0,0 +1,104 @@
+// macOS Phase 1 PoC: run the MediaPipe Tasks Vision *Objective-C* API on macOS.
+// Loads a JPEG with ImageIO, wraps it in a BGRA CVPixelBuffer, and runs
+// MPPHandLandmarker in image mode.
+#import <CoreGraphics/CoreGraphics.h>
+#import <CoreVideo/CoreVideo.h>
+#import <Foundation/Foundation.h>
+#import <ImageIO/ImageIO.h>
+
+#import "mediapipe/tasks/ios/vision/core/sources/MPPImage.h"
+#import "mediapipe/tasks/ios/vision/hand_landmarker/sources/MPPHandLandmarker.h"
+
+static CVPixelBufferRef CreateBGRAPixelBufferFromFile(NSString *path) {
+  NSURL *url = [NSURL fileURLWithPath:path];
+  CGImageSourceRef source = CGImageSourceCreateWithURL((__bridge CFURLRef)url, NULL);
+  if (!source) return NULL;
+  CGImageRef cgImage = CGImageSourceCreateImageAtIndex(source, 0, NULL);
+  CFRelease(source);
+  if (!cgImage) return NULL;
+
+  size_t width = CGImageGetWidth(cgImage);
+  size_t height = CGImageGetHeight(cgImage);
+
+  NSDictionary *attrs = @{(id)kCVPixelBufferCGImageCompatibilityKey : @YES};
+  CVPixelBufferRef pixelBuffer = NULL;
+  CVReturn status =
+      CVPixelBufferCreate(kCFAllocatorDefault, width, height, kCVPixelFormatType_32BGRA,
+                          (__bridge CFDictionaryRef)attrs, &pixelBuffer);
+  if (status != kCVReturnSuccess) {
+    CGImageRelease(cgImage);
+    return NULL;
+  }
+
+  CVPixelBufferLockBaseAddress(pixelBuffer, 0);
+  CGColorSpaceRef colorSpace = CGColorSpaceCreateDeviceRGB();
+  CGContextRef context = CGBitmapContextCreate(
+      CVPixelBufferGetBaseAddress(pixelBuffer), width, height, 8,
+      CVPixelBufferGetBytesPerRow(pixelBuffer), colorSpace,
+      kCGImageAlphaPremultipliedFirst | kCGBitmapByteOrder32Little);
+  CGContextDrawImage(context, CGRectMake(0, 0, width, height), cgImage);
+  CGContextRelease(context);
+  CGColorSpaceRelease(colorSpace);
+  CVPixelBufferUnlockBaseAddress(pixelBuffer, 0);
+  CGImageRelease(cgImage);
+  return pixelBuffer;
+}
+
+int main(int argc, char **argv) {
+  @autoreleasepool {
+    if (argc < 3) {
+      fprintf(stderr, "usage: %s <model.task> <image>\n", argv[0]);
+      return 2;
+    }
+    NSString *modelPath = [NSString stringWithUTF8String:argv[1]];
+    NSString *imagePath = [NSString stringWithUTF8String:argv[2]];
+
+    CVPixelBufferRef pixelBuffer = CreateBGRAPixelBufferFromFile(imagePath);
+    if (!pixelBuffer) {
+      fprintf(stderr, "failed to load image\n");
+      return 1;
+    }
+
+    NSError *error = nil;
+    MPPImage *image = [[MPPImage alloc] initWithPixelBuffer:pixelBuffer error:&error];
+    CVPixelBufferRelease(pixelBuffer);
+    if (!image) {
+      fprintf(stderr, "MPPImage init failed: %s\n", error.localizedDescription.UTF8String);
+      return 1;
+    }
+
+    MPPHandLandmarkerOptions *options = [[MPPHandLandmarkerOptions alloc] init];
+    options.baseOptions.modelAssetPath = modelPath;
+    options.runningMode = MPPRunningModeImage;
+    options.numHands = 2;
+
+    MPPHandLandmarker *landmarker = [[MPPHandLandmarker alloc] initWithOptions:options
+                                                                         error:&error];
+    if (!landmarker) {
+      fprintf(stderr, "HandLandmarker init failed: %s\n", error.localizedDescription.UTF8String);
+      return 1;
+    }
+
+    MPPHandLandmarkerResult *result = [landmarker detectImage:image error:&error];
+    if (!result) {
+      fprintf(stderr, "detect failed: %s\n", error.localizedDescription.UTF8String);
+      return 1;
+    }
+
+    printf("hands detected: %lu\n", (unsigned long)result.landmarks.count);
+    for (NSUInteger i = 0; i < result.landmarks.count; i++) {
+      NSArray<MPPNormalizedLandmark *> *hand = result.landmarks[i];
+      MPPCategory *handedness = result.handedness[i].firstObject;
+      printf("hand[%lu]: handedness=%s landmarks=%lu\n", (unsigned long)i,
+             handedness.categoryName.UTF8String, (unsigned long)hand.count);
+      for (NSUInteger j = 0; j < MIN((NSUInteger)3, hand.count); j++) {
+        printf("  lm[%lu] = (%.3f, %.3f, %.3f)\n", (unsigned long)j, hand[j].x, hand[j].y,
+               hand[j].z);
+      }
+    }
+
+    BOOL ok = result.landmarks.count > 0 && result.landmarks.firstObject.count == 21;
+    printf(ok ? "OBJC SMOKE TEST PASSED\n" : "OBJC SMOKE TEST FAILED\n");
+    return ok ? 0 : 1;
+  }
+}
