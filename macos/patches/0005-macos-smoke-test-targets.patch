+++ b/mediapipe/tasks/c/vision/hand_landmarker/smoke_macos.cc
@@ -0,0 +1,67 @@
+// macOS PoC: run MediaPipe Hand Landmarker (C API) on a still image.
+#include <cstdio>
+#include <cstdlib>
+
+#include "mediapipe/tasks/c/core/base_options.h"
+#include "mediapipe/tasks/c/core/mp_status.h"
+#include "mediapipe/tasks/c/vision/core/image.h"
+#include "mediapipe/tasks/c/vision/hand_landmarker/hand_landmarker.h"
+#include "mediapipe/tasks/c/vision/hand_landmarker/hand_landmarker_result.h"
+
+int main(int argc, char** argv) {
+  if (argc < 3) {
+    std::fprintf(stderr, "usage: %s <model.task> <image>\n", argv[0]);
+    return 2;
+  }
+  char* err = nullptr;
+
+  MpImagePtr image = nullptr;
+  if (MpImageCreateFromFile(argv[2], &image, &err) != kMpOk) {
+    std::fprintf(stderr, "MpImageCreateFromFile failed: %s\n", err ? err : "?");
+    return 1;
+  }
+
+  HandLandmarkerOptions options = {};
+  options.base_options.model_asset_path = argv[1];
+  options.base_options.delegate = Delegate::CPU;
+  options.running_mode = RunningMode::IMAGE;
+  options.num_hands = 2;
+  options.min_hand_detection_confidence = 0.5f;
+  options.min_hand_presence_confidence = 0.5f;
+  options.min_tracking_confidence = 0.5f;
+
+  MpHandLandmarkerPtr landmarker = nullptr;
+  if (MpHandLandmarkerCreate(&options, &landmarker, &err) != kMpOk) {
+    std::fprintf(stderr, "MpHandLandmarkerCreate failed: %s\n", err ? err : "?");
+    return 1;
+  }
+
+  HandLandmarkerResult result = {};
+  if (MpHandLandmarkerDetectImage(landmarker, image, /*options=*/nullptr,
+                                  &result, &err) != kMpOk) {
+    std::fprintf(stderr, "DetectImage failed: %s\n", err ? err : "?");
+    return 1;
+  }
+
+  std::printf("hands detected: %u\n", result.hand_landmarks_count);
+  for (uint32_t i = 0; i < result.hand_landmarks_count; ++i) {
+    const auto& lms = result.hand_landmarks[i];
+    const char* handedness = "?";
+    if (i < result.handedness_count && result.handedness[i].categories_count > 0) {
+      handedness = result.handedness[i].categories[0].category_name;
+    }
+    std::printf("hand[%u]: handedness=%s landmarks=%u\n", i, handedness,
+                lms.landmarks_count);
+    for (uint32_t j = 0; j < lms.landmarks_count && j < 3; ++j) {
+      std::printf("  lm[%u] = (%.3f, %.3f, %.3f)\n", j, lms.landmarks[j].x,
+                  lms.landmarks[j].y, lms.landmarks[j].z);
+    }
+  }
+
+  bool ok = result.hand_landmarks_count > 0 &&
+            result.hand_landmarks[0].landmarks_count == 21;
+  MpHandLandmarkerCloseResult(&result);
+  MpHandLandmarkerClose(landmarker, nullptr);
+  std::printf(ok ? "SMOKE TEST PASSED\n" : "SMOKE TEST FAILED\n");
+  return ok ? 0 : 1;
+}
